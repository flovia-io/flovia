{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "../dist-server",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@flovia/core/*": ["../core/*"],
      "@flovia/core": ["../core/index.ts"],
      "@flovia/connectors/*": ["../connectors/*"],
      "@flovia/connectors": ["../connectors/index.ts"],
      "@flovia/main/*": ["../main/*"],
      "@flovia/main": ["../main/index.ts"],
      "@flovia/server/*": ["../server/*"],
      "@flovia/server": ["../server/index.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "../core/**/*.ts",
    "../connectors/**/*.ts",
    "./**/*.ts"
  ],
  "exclude": [
    "../node_modules",
    "../main/**/*.ts",
    "../renderer/**/*"
  ]
}
