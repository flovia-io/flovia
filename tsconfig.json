{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "@flovia/core/*": ["./core/*"],
      "@flovia/core": ["./core/index.ts"],
      "@flovia/connectors/*": ["./connectors/*"],
      "@flovia/connectors": ["./connectors/index.ts"],
      "@flovia/main/*": ["./main/*"],
      "@flovia/main": ["./main/index.ts"]
    },
    "outDir": "dist-main",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["main/**/*.ts", "core/**/*.ts", "connectors/**/*.ts"],
  "exclude": ["node_modules", "renderer", "server"]
}
